{
  "name": "elementar-rt",
  "description": "Elementar RT - Free and open-source Angular UI components and Admin panel based on Material 3 and Tailwind",
  "version": "1.0.0",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/randrost/elementar-rt/issues"
  },
  "homepage": "https://elementar-rt.r-tulika.me",
  "keywords": [
    "Elementar RT",
    "angular admin",
    "admin panel",
    "angular dashboard",
    "angular admin panel",
    "angular material components",
    "angular admin template",
    "angular ui"
  ],
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:app": "ng test elementar-rt --watch=false --browsers=ChromeHeadlessNoSandbox --no-progress",
    "test:components": "ng test components --watch=false --browsers=ChromeHeadlessNoSandbox --no-progress",
    "test:ci": "npm run test:components && npm run test:app",
    "update:check": "ng update",
    "build": "ng build",
    "build:components:prod": "cross-env NODE_OPTIONS=--max-old-space-size=8192 ng build components --configuration production",
    "build:prod": "ng build --configuration production",
    "changelog": "auto-changelog -p && git add CHANGELOG.md",
    "prepare": "husky"
  },
  "private": true,
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "dependencies": {
    "@angular/animations": "^21.2.17",
    "@angular/cdk": "^21.2.14",
    "@angular/common": "^21.2.17",
    "@angular/compiler": "^21.2.17",
    "@angular/core": "^21.2.17",
    "@angular/forms": "^21.2.17",
    "@angular/localize": "^21.2.17",
    "@angular/material": "^21.2.14",
    "@angular/platform-browser": "^21.2.17",
    "@angular/platform-browser-dynamic": "^21.2.17",
    "@angular/platform-server": "^21.2.17",
    "@angular/router": "^21.2.17",
    "@angular/ssr": "^21.2.18",
    "@ctrl/tinycolor": "^4.1.0",
    "@dicebear/collection": "^9.4.2",
    "@dicebear/core": "^9.4.2",
    "@iconify-json/circle-flags": "^1.2.10",
    "@iconify-json/ph": "^1.2.2",
    "@ngrx/signals": "^21.1.1",
    "@ngrx/store": "^21.1.1",
    "@tiptap/core": "2.10.2",
    "@tiptap/extension-bubble-menu": "2.10.2",
    "@tiptap/extension-code-block": "2.10.2",
    "@tiptap/extension-dropcursor": "2.10.2",
    "@tiptap/extension-floating-menu": "2.10.2",
    "@tiptap/extension-history": "2.10.2",
    "@tiptap/extension-horizontal-rule": "2.10.3",
    "@tiptap/extension-image": "2.10.2",
    "@tiptap/extension-link": "2.10.4",
    "@tiptap/extension-list-item": "2.10.2",
    "@tiptap/extension-ordered-list": "2.10.2",
    "@tiptap/extension-placeholder": "2.10.2",
    "@tiptap/extension-youtube": "2.10.2",
    "@tiptap/pm": "2.10.2",
    "@tiptap/starter-kit": "2.10.2",
    "auto-changelog": "^2.6.0",
    "autoprefixer": "^10.5.0",
    "awesome-phonenumber": "^6.12.0",
    "copyfiles": "^2.4.1",
    "d3": "^7.9.0",
    "echarts": "^6.1.0",
    "emojibase-data": "^16.0.3",
    "express": "^4.22.2",
    "iconify-icon": "^3.0.2",
    "libphonenumber-js": "^1.13.6",
    "lightningcss": "^1.32.0",
    "marked": "^18.0.5",
    "ngx-markdown": "^21.3.0",
    "postcss": "^8.5.15",
    "prismjs": "^1.29.0",
    "rxjs": "~7.8.0",
    "shiki": "^3.23.0",
    "tslib": "^2.3.0",
    "uuid": "^11.1.1",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.18",
    "@angular/cli": "^21.2.18",
    "@angular/compiler-cli": "^21.2.17",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/typography": "^0.5.16",
    "@types/d3": "^7.4.3",
    "@types/express": "^5.0.6",
    "@types/jasmine": "~5.1.15",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^20.19.42",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.5.0",
    "cross-env": "^10.1.0",
    "husky": "^9.1.7",
    "jasmine-core": "~5.8.0",
    "jsdom": "^26.1.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.2.0",
    "ng-packagr": "^21.2.5",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "typescript": "~5.9.3"
  },
  "husky": {
    "pre-push": "npm run changelog"
  }
}
