{
  "name": "@elementar-rt/components",
  "description": "Elementar RT Components - Free and open source Angular UI components based on Material 3 and Tailwind",
  "version": "0.6.57",
  "repository": {
    "type": "git",
    "url": "https://github.com/randrost/elementar-rt.git"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/randrost/elementar-rt/issues"
  },
  "homepage": "https://elementar-rt.r-tulika.me",
  "keywords": [
    "Elementar RT",
    "angular admin",
    "admin panel",
    "angular dashboard",
    "angular admin panel",
    "angular material components",
    "angular admin template",
    "angular ui"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.schematics.json",
    "postbuild": "copyfiles schematics/*/schema.json schematics/*/files/** schematics/collection.json ../../dist/components/"
  },
  "ng-add": {
    "save": "devDependencies"
  },
  "schematics": "./schematics/collection.json",
  "devDependencies": {
    "tailwindcss": "^4.3.0",
    "postcss": "^8.5.15",
    "autoprefixer": "^10.5.0",
    "@types/jsdom": "^21.1.7"
  },
  "peerDependencies": {
    "@angular/cdk": "^20.2.14",
    "@angular/common": "^20.3.0",
    "@angular/localize": "^20.3.0",
    "@angular/compiler": "^20.3.0",
    "@angular/core": "^20.3.0",
    "@angular/forms": "^20.3.0",
    "@angular/material": "^20.2.14",
    "@angular/router": "^20.3.0",
    "@angular/ssr": "^20.3.0"
  },
  "dependencies": {
    "tslib": "^2.3.0",
    "jsdom": "^26.1.0"
  },
  "sideEffects": false,
  "exports": {
    "./styles/themes/": "./styles/themes/"
  }
